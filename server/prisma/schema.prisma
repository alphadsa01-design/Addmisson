datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  password     String
  name         String
  designation  String?
  isVerified   Boolean     @default(true)
  otpCode      String?
  otpExpiresAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLogin    DateTime?
  admissions   Admission[] @relation("AdmittedBy")

  @@index([email])
}

model Institute {
  id         String      @id @default(uuid())
  name       String
  code       String      @unique
  district   String
  state      String
  admissions Admission[]
  createdAt  DateTime    @default(now())
}

model Trade {
  id            String      @id @default(uuid())
  name          String
  code          String      @unique
  durationYears Int
  admissions    Admission[]
  createdAt     DateTime    @default(now())
}

model Student {
  id              String     @id @default(uuid())
  name            String
  dateOfBirth     DateTime?
  gender          String
  category        String // General, OBC, SC, ST, etc.
  religion        String?
  fatherName      String
  motherName      String?
  mobileNumber    String
  email           String?
  address         String
  state           String?
  district        String?
  pinCode         String?
  alternateMobile String?
  bloodGroup      String?
  nationality     String?    @default("Indian")
  admission       Admission?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([name])
  @@index([fatherName])
  @@index([mobileNumber])
  @@index([gender])
  @@index([category])
  @@index([createdAt(sort: Desc)])
}

model Admission {
  id              String          @id @default(uuid())
  sno             String?
  admissionNumber String          @unique // E.g., ITI/2026/0001
  admissionDate   DateTime?
  studentId       String          @unique
  student         Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instituteId     String
  institute       Institute       @relation(fields: [instituteId], references: [id])
  tradeId         String
  trade           Trade           @relation(fields: [tradeId], references: [id])
  academicYear    String // e.g. "2026-2027"
  status          AdmissionStatus @default(PENDING)
  feeStatus       FeeStatus       @default(UNPAID)
  admittedById    String
  admittedBy      User            @relation("AdmittedBy", fields: [admittedById], references: [id])
  remarks         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([academicYear])
  @@index([status])
  @@index([feeStatus])
  @@index([admissionDate])
  @@index([tradeId])
  @@index([instituteId])
  @@index([academicYear, tradeId])
  @@index([createdAt(sort: Desc)])
  @@index([admittedById])
}

enum AdmissionStatus {
  PENDING
  VERIFIED
  COMPLETED
  CANCELLED
}

enum FeeStatus {
  PAID
  UNPAID
  PARTIAL
}
